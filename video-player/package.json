{
  "name": "tesil-media-player",
  "version": "1.1.6",
  "private": true,
  "description": "Tesil Media Player for Windows (desktop)",
  "author": "becknerd",
  "homepage": "https://github.com/becknerd/Tesil-Player",
  "repository": {
    "type": "git",
    "url": "https://github.com/becknerd/Tesil-Player.git"
  },
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win zip --x64"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.tesil.mediaplayer",
    "productName": "Tesil Media Player",
    "copyright": "Copyright 2026",
    "artifactName": "Tesil-Media-Player-${version}-Windows-portable.${ext}",
    "npmRebuild": false,
    "publish": "never",
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    }
  }
}
