{
  "name": "custom-video-player",
  "version": "1.0.3",
  "private": true,
  "description": "Custom video player for Windows (desktop)",
  "author": "becknerd",
  "homepage": "https://github.com/becknerd/Tesil-Player",
  "repository": {
    "type": "git",
    "url": "https://github.com/becknerd/Tesil-Player.git"
  },
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.custom.videoplayer",
    "productName": "CustomVideoPlayer",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.cjs",
      "preload.cjs",
      "index.html",
      "player.js",
      "styles.css",
      "manifest.webmanifest",
      "sw.js",
      "icons/**/*"
    ],
    "win": {
      "artifactName": "${name}-${version}-Windows-x64.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
