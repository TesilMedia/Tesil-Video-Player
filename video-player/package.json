{
  "name": "custom-video-player",
  "version": "1.1.0",
  "private": true,
  "description": "Custom video player for Windows (desktop)",
  "author": "becknerd",
  "homepage": "https://github.com/becknerd/Tesil-Player",
  "repository": {
    "type": "git",
    "url": "https://github.com/becknerd/Tesil-Player.git"
  },
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.customvideoplayer.app",
    "productName": "CustomVideoPlayer",
    "copyright": "Copyright 2026",
    "npmRebuild": false,
    "publish": "never",
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-Windows-Portable.${ext}"
    }
  }
}
