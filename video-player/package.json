{
  "name": "tesil-video-player",
  "version": "1.1.12",
  "private": true,
  "description": "Tesil Video Player for Windows (desktop)",
  "author": "becknerd",
  "homepage": "https://github.com/TesilMedia/Tesil-Video-Player",
  "repository": {
    "type": "git",
    "url": "https://github.com/TesilMedia/Tesil-Video-Player.git"
  },
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win dir --x64"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3",
    "rcedit": "^4.0.1",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.tesil.videoplayer",
    "productName": "Tesil Video Player",
    "copyright": "Copyright 2026",
    "npmRebuild": false,
    "publish": "never",
    "afterPack": "./scripts/after-pack-win-metadata.cjs",
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
